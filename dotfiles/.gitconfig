	name = crochee
	email = 13522570308@139.com

[github]
	user = crochee

[core]
	editor = nvim
    hooksPath = ~/.dotfiles/config/githooks

[pull]
	rebase = true

[init]
	defaultBranch = master

[push]
	default = simple
	followTags = true

[fetch]
	prune = true

[grep]
	lineNumber = true

[help]
	autocorrect = 1
