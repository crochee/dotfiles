# Environment variables

# Set default editor
export EDITOR="nvim"
export VISUAL="nvim"

# Base Directory Specification
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

export XDG_DOWNLOAD_DIR="$HOME/Downloads"


# Set TERM for proper terminal capabilities
export TERM=xterm-256color

# Set history size
export HISTSIZE=10000
export HISTFILESIZE=10000

# Set less options
export LESS="-R"

# Set grep options
export GREP_COLOR="36;40"

if type go >/dev/null 2>&1 && go env | grep -q 'GOPROXY=direct'; then
    go env -w GOPROXY=https://goproxy.io,https://goproxy.cn,https://proxy.golang.org,direct
    go env -w GO111MODULE=on
fi
