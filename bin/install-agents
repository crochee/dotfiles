#!/usr/bin/env bash
# Install agents from this repo into a target editor's agents directory.
#
# Usage:
#   install-agents [-f] <editor-name>  → ~/.<editor-name>/agents
#   install-agents <editor-name> [-f]  → ~/.<editor-name>/agents
#
# Options:
#   -f    Force mode: clean target directory before copying all agents
#   -d    Delete mode: remove installed agents that exist in source directory

set -euo pipefail

# Script directory (parent = dotfiles root)
DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"

SOURCE_DIR="$DOTFILES/agents"

FORCE=0
DELETE_MODE=0
EDITOR_NAME=""

usage() {
    echo "Usage: install-agents [-f] [-d] <editor-name>"
    echo "       install-agents <editor-name> [-f] [-d]"
    echo "  -f    Force mode: clean target and copy all agents"
    echo "  -d    Delete mode: remove installed agents that exist in source directory"
    echo "  Target: ~/.<editor-name>/agents"
    exit 1
}

while [ $# -gt 0 ]; do
    case "$1" in
        -f) FORCE=1 ; shift ;;
        -d) DELETE_MODE=1 ; shift ;;
        -*) usage ;;
        *)
            if [ -n "$EDITOR_NAME" ]; then
                usage
            fi
            EDITOR_NAME="$1"
            shift
            ;;
    esac
done

if [ -z "$EDITOR_NAME" ]; then
    usage
fi

# Resolve target directory: absolute/tilde paths used directly, otherwise ~/.<name>/agents
case "$EDITOR_NAME" in
    /*)  TARGET_DIR="$EDITOR_NAME" ;;
    ~/*) TARGET_DIR="${EDITOR_NAME/#\~/$HOME}" ;;
    *)   TARGET_DIR="$HOME/.$EDITOR_NAME/agents" ;;
esac

if [ ! -d "$SOURCE_DIR" ]; then
    echo "Error: source $SOURCE_DIR not found" >&2
    exit 1
fi

# Collect agent files
declare -A AGENT_MAP
for item in "$SOURCE_DIR"/*.md; do
    [ -f "$item" ] || continue
    name="$(basename "$item" .md)"
    AGENT_MAP["$name"]="$item"
done

if [ ${#AGENT_MAP[@]} -eq 0 ]; then
    echo "Error: no agent files found in $SOURCE_DIR" >&2
    exit 1
fi

# Ensure target directory exists
mkdir -p "$TARGET_DIR"

# Delete mode: remove installed agents that exist in source directory
if [ "$DELETE_MODE" -eq 1 ]; then
    if [ ! -d "$TARGET_DIR" ]; then
        echo "Error: target directory $TARGET_DIR does not exist" >&2
        exit 1
    fi

    REMOVED=0
    SKIPPED=0

    echo "Removing agents from $TARGET_DIR ..."
    for name in $(echo "${!AGENT_MAP[@]}" | tr ' ' '\n' | sort); do
        target="$TARGET_DIR/$name.md"
        if [ -f "$target" ]; then
            echo "  Removing: $name"
            rm -f "$target"
            REMOVED=$((REMOVED + 1))
        else
            echo "  Skipping: $name (not installed)"
            SKIPPED=$((SKIPPED + 1))
        fi
    done

    echo "Done: $REMOVED agents removed, $SKIPPED agents skipped"

    # Exit if only delete mode (not combined with force)
    if [ "$FORCE" -eq 0 ]; then
        exit 0
    fi
fi

# Clean target directory in force mode
if [ "$FORCE" -eq 1 ]; then
    if [ -d "$TARGET_DIR" ]; then
        echo "Cleaning $TARGET_DIR (force mode) ..."
        find "$TARGET_DIR" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
    fi
fi

# Sync agents
echo "Installing ${#AGENT_MAP[@]} agents to $TARGET_DIR ..."
for name in $(echo "${!AGENT_MAP[@]}" | tr ' ' '\n' | sort); do
    src="${AGENT_MAP[$name]}"
    target="$TARGET_DIR/$name.md"
    if [ -f "$target" ]; then
        echo "  $name (overwrite)"
        cp -f "$src" "$target"
    else
        echo "  $name (new)"
        cp "$src" "$target"
    fi
done

echo "Done: ${#AGENT_MAP[@]} agents installed"